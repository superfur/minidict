{
    "name": "minidict",
    "version": "2.5.0",
    "description": "一个简单易用的命令行词典工具",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "dict": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "clean": "rm -rf dist",
        "build": "bun run clean && tsc && chmod +x dist/cli.js",
        "dev": "tsc -w",
        "test": "jest",
        "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepublishOnly": "bun run build",
        "prepare": "husky || true",
        "start": "node dist/cli.js"
    },
    "lint-staged": {
        "*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "overrides": {
        "@babel/helpers": "^7.26.10",
        "ajv": "^6.14.0",
        "flatted": "^3.4.0",
        "js-yaml": "^3.14.2",
        "picomatch": "^2.3.2",
        "minimatch": "^3.1.3",
        "brace-expansion": "^1.1.12",
        "ip-address": "^10.2.0"
    },
    "keywords": [
        "dictionary",
        "cli",
        "translate",
        "bing",
        "youdao"
    ],
    "author": "Septem <septem@gmail.com>",
    "license": "MIT",
    "dependencies": {
        "chalk": "^4.1.2",
        "cheerio": "^1.2.0",
        "commander": "^12.1.0",
        "https-proxy-agent": "^7.0.6",
        "node-fetch": "^3.3.2",
        "socks-proxy-agent": "^8.0.5"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^18.19.130",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "eslint": "^8.57.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^15.5.2",
        "prettier": "^3.8.4",
        "ts-jest": "^29.4.11",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/superfur/minidict.git"
    },
    "bugs": {
        "url": "https://github.com/superfur/minidict/issues"
    },
    "homepage": "https://github.com/superfur/minidict#readme"
}
